<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane styleClass="root-pane" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="project.sudokuproject.Controller.GameController">
    <top>
        <VBox alignment="CENTER" spacing="8" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="12" left="20" right="20" top="22" />
            </padding>
            <Label styleClass="title-label" text="Sudoku 6x6" />
        </VBox>
    </top>

    <center>
        <GridPane fx:id="boardGrid" alignment="CENTER" hgap="0" vgap="0" BorderPane.alignment="CENTER" />
    </center>

    <bottom>
        <VBox alignment="CENTER" spacing="14" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="24" left="20" right="20" top="12" />
            </padding>
            <HBox alignment="CENTER" spacing="12">
                <Button fx:id="btnNewGame" onAction="#startNewGame" styleClass="primary-button" text="Nuevo juego" />
                <Button fx:id="btnHelp" onAction="#requestHint" styleClass="secondary-button" text="Ayuda" />
                <Button fx:id="btnClear" onAction="#clearEditableCells" styleClass="secondary-button" text="Limpiar" />
            </HBox>
            <HBox alignment="CENTER" spacing="18">
                <Label fx:id="hintCounterLabel" styleClass="counter-label" text="Ayudas usadas: 0" />
                <Label fx:id="messageLabel" styleClass="message-label" text="" />
            </HBox>
        </VBox>
    </bottom>
</BorderPane>
